{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "env": {}
    },
      "shrimp-task-manager": {
        "command": "node",
        "args": [
          "/Users/sonnyoung/workspace/mcp-shrimp-task-manager/dist/index.js"
        ],
        "env": {
          "DATA_DIR": "/Users/sonnyoung/workspace/courses/invoice-web/shrimp_data",
          "TEMPLATES_USE": "en",
          "ENABLE_GUI": "true"
        }
      },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    }
  }
}